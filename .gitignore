# ── Secrets ──────────────────────────────────────
.env
*.env

# ── Python ───────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Generated outputs (never commit tip sheets) ──
# Note: output/ itself is a tracked package (emailer, renderer, templates)
# — only the regenerated artifact subdirectories are ignored.
output/tipsheets/
output/candidates/
output/paper_desk/

# ── Logs (all runtime logs; scan_log.json untracked 2026-07-21 —
#    it appended ~47k lines per commit and is regenerated on each run) ──
logs/

# ── Runtime model state (cached in CI; do not commit) ──
data/iv_history/*.json

# ── OS / IDE ─────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
