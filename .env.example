# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Data & AI APIs ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
NEWS_API_KEY=...
TRADIER_API_KEY=...
TRADIER_SANDBOX=true       # set to false for live Tradier account

# ── Email delivery ────────────────────────────────────
# Gmail: use an App Password (not your account password).
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate a password for "Mail" and paste it below
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENTS=you@gmail.com,partner@gmail.com
